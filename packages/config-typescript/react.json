{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./root.json",
  "compilerOptions": {
    "jsx": "react-jsx",

    "useDefineForClassFields": true,
    "module": "ESNext",

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
  }
}